# ==============================================================================
#  Arr Stack — Environment Configuration
# ==============================================================================
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  NEVER commit .env to git — it contains secrets!
# ==============================================================================


# ==============================================================================
#  SYSTEM
# ==============================================================================

# User and group IDs for file permissions.
# Find yours by running:  id
# Look for uid=XXXX(username) gid=XXXX(groupname)
PUID=1000
PGID=1000

# Your timezone. Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York


# ==============================================================================
#  PATHS
# ==============================================================================

# Root directory for all stack data. All service configs, downloads, and media
# live under this path.
# Set to . to keep everything in this folder (recommended).
# Or set an absolute path to store data elsewhere (e.g. /volume1/data).
DATA_ROOT=.

# The setup script creates this directory tree automatically:
#
#   ${DATA_ROOT}/
#   ├── config/                       # Service configs (auto-populated on first run)
#   │   ├── audiobookshelf/
#   │   ├── audiobookshelf-meta/
#   │   ├── bazarr/
#   │   ├── jellyfin/
#   │   ├── jellyfin-cache/
#   │   ├── kavita/
#   │   ├── lazylibrarian/
#   │   ├── lidarr/
#   │   ├── prowlarr/
#   │   ├── questarr/
#   │   ├── radarr/
#   │   ├── sabnzbd/
#   │   ├── seerr/                    # Must be owned by 1000:1000 (see compose.yaml)
#   │   ├── sonarr/
#   │   └── transmission/
#   ├── downloads/                    # Temporary download staging area
#   └── media/                        # Your organized media library
#       ├── audiobooks/
#       ├── books/
#       ├── games/
#       ├── movies/
#       ├── music/
#       └── tv/


# ==============================================================================
#  OPTIONAL SERVICES
# ==============================================================================
# By default, the core stack runs: VPN, download clients, Prowlarr, Radarr,
# Sonarr, Bazarr, Jellyfin, and Seerr.
#
# Enable additional services by listing their profiles below (comma-separated).
# Remove any you don't need:
#   lazylibrarian  → LazyLibrarian (ebook search & download)
#   kavita         → Kavita (ebook reader)
#   audiobookshelf → Audiobookshelf (audiobook server)
COMPOSE_PROFILES=lazylibrarian,kavita,audiobookshelf



# ==============================================================================
#  VPN (WireGuard via Gluetun)
# ==============================================================================
#  Gluetun tunnels your download traffic through a VPN.
#  You need a VPN provider that supports WireGuard.
#
#  There are TWO ways to configure Gluetun depending on your VPN provider:
#
#  OPTION A — Named provider (ProtonVPN, Mullvad, Surfshark, NordVPN, etc.)
#    Gluetun has built-in support for many providers. You set the provider name
#    and a country/city, and Gluetun picks the best server automatically.
#    This also enables provider-specific features like port forwarding (NAT-PMP).
#    Docs: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
#
#  OPTION B — Custom WireGuard (any provider)
#    If your provider is not in Gluetun's list, use VPN_SERVICE_PROVIDER=custom
#    and paste the raw WireGuard keys/endpoint from your .conf file.
#    Port forwarding is NOT available with custom providers.
#
# ==============================================================================

# --- Provider selection ---
# Set to your provider name (protonvpn, mullvad, surfshark, nordvpn, etc.)
# or "custom" for raw WireGuard config.
VPN_SERVICE_PROVIDER=custom

# --- OPTION A: Named provider settings ---
# Your WireGuard private key (from your provider's WireGuard config generator)
# For ProtonVPN: https://account.protonvpn.com/downloads -> WireGuard configuration
WIREGUARD_PRIVATE_KEY=your_private_key_here

# Country for server selection (e.g. Netherlands, Switzerland, Japan)
# Only used with named providers — ignored when VPN_SERVICE_PROVIDER=custom.
SERVER_COUNTRIES=

# Port forwarding via NAT-PMP (ProtonVPN, PIA, and others support this).
# Dramatically improves torrent peer connectivity. Only works with named providers.
VPN_PORT_FORWARDING=off

# --- OPTION B: Custom WireGuard settings ---
# Only needed when VPN_SERVICE_PROVIDER=custom. Leave blank for named providers.

# Server's WireGuard public key (from [Peer] section)
WIREGUARD_PUBLIC_KEY=

# Your WireGuard tunnel address (from [Interface] Address, e.g. 10.2.0.2/32)
WIREGUARD_ADDRESS=

# VPN server IP and port (from [Peer] Endpoint, e.g. 123.45.67.89:51820)
VPN_ENDPOINT_IP=
VPN_ENDPOINT_PORT=

# --- Advanced ---
# Keep tunnel alive through aggressive NAT (useful on some networks)
WIREGUARD_PERSISTENT_KEEPALIVE_INTERVAL=

# ==============================================================================
# ==============================================================================
#  HARDWARE — GPU Transcoding (Optional)
# ==============================================================================
#  GPU hardware transcoding is configured automatically by: arr setup
#  It detects your GPU and creates compose.override.yaml with the right devices.
#
#  No manual GPU configuration needed in .env anymore.
