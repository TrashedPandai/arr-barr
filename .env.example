# ==============================================================================
#  Arr Stack — Environment Configuration
# ==============================================================================
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  NEVER commit .env to git — it contains secrets!
# ==============================================================================


# ==============================================================================
#  SYSTEM
# ==============================================================================

# User and group IDs for file permissions.
# Find yours by running:  id
# Look for uid=XXXX(username) gid=XXXX(groupname)
PUID=1000
PGID=1000

# Your timezone. Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York


# ==============================================================================
#  PATHS
# ==============================================================================

# Root directory for all stack data. All service configs, downloads, and media
# live under this path.
# Set to . to keep everything in this folder (recommended).
# Or set an absolute path to store data elsewhere (e.g. /volume1/data).
DATA_ROOT=.

# The setup script creates this directory tree automatically:
#
#   ${DATA_ROOT}/
#   ├── config/                       # Service configs (auto-populated on first run)
#   │   ├── audiobookshelf/
#   │   ├── audiobookshelf-meta/
#   │   ├── bazarr/
#   │   ├── jellyfin/
#   │   ├── jellyfin-cache/
#   │   ├── kavita/
#   │   ├── lazylibrarian/
#   │   ├── lidarr/
#   │   ├── prowlarr/
#   │   ├── questarr/
#   │   ├── radarr/
#   │   ├── sabnzbd/
#   │   ├── seerr/                    # Must be owned by 1000:1000 (see compose.yaml)
#   │   ├── sonarr/
#   │   └── transmission/
#   ├── downloads/                    # Temporary download staging area
#   └── media/                        # Your organized media library
#       ├── audiobooks/
#       ├── books/
#       ├── games/
#       ├── movies/
#       ├── music/
#       └── tv/


# ==============================================================================
#  OPTIONAL SERVICES
# ==============================================================================
# By default, the core stack runs: VPN, download clients, Prowlarr, Radarr,
# Sonarr, Bazarr, Jellyfin, and Seerr.
#
# Enable additional services by listing their profiles below (comma-separated).
# Remove any you don't need:
#   lazylibrarian  → LazyLibrarian (ebook search & download)
#   kavita         → Kavita (ebook reader)
#   audiobookshelf → Audiobookshelf (audiobook server)
COMPOSE_PROFILES=lazylibrarian,kavita,audiobookshelf



# ==============================================================================
#  VPN (WireGuard via Gluetun)
# ==============================================================================
#  Gluetun tunnels your download traffic through a VPN.
#  You need a VPN provider that supports WireGuard.
#
#  Popular providers and setup guides:
#    - Mullvad:    https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/mullvad.md
#    - ProtonVPN:  https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/protonvpn.md
#    - Surfshark:  https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/surfshark.md
#    - Windscribe: https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/windscribe.md
#    - NordVPN:    https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/nordvpn.md
#
#  Full provider list: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
#
#  Get these values from your VPN provider's WireGuard config file.

# Your WireGuard private key (from [Interface] section)
WIREGUARD_PRIVATE_KEY=your_private_key_here

# Server's WireGuard public key (from [Peer] section)
WIREGUARD_PUBLIC_KEY=server_public_key_here

# Your WireGuard tunnel address (from [Interface] Address, e.g. 10.2.0.2/32)
WIREGUARD_ADDRESS=10.2.0.2/32

# VPN server IP and port (from [Peer] Endpoint, e.g. 123.45.67.89:51820)
VPN_ENDPOINT_IP=123.45.67.89
VPN_ENDPOINT_PORT=51820


# ==============================================================================
#  HARDWARE — GPU Transcoding (Optional)
# ==============================================================================
#  Jellyfin can use a GPU for hardware-accelerated video transcoding.
#  This is optional — without a GPU, Jellyfin uses CPU transcoding (slower
#  but works fine for a few simultaneous streams).
#
#  If you DON'T have a GPU:
#    Remove the "devices:" block from the jellyfin service in compose.yaml.
#    You can leave these variables empty or remove them entirely.
#
#  If you DO have a GPU, find your device paths:
#    ls -la /dev/dri/
#  You should see renderD128 and card0 (or similar numbers).

# Path to the GPU render device (e.g. /dev/dri/renderD128)
GPU_RENDER_DEVICE=/dev/dri/renderD128

# Path to the GPU card device (e.g. /dev/dri/card0)
GPU_CARD_DEVICE=/dev/dri/card0
