    echo -e "  ${local_dim}Stack location: $ARR_HOME${local_reset}"
    echo ""
}

# в”Ђв”Ђ Command Dispatch в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

case "${1:-}" in
    setup)
        bash "$CLI_DIR/setup.sh"
        ;;
    status|st)
        bash "$CLI_DIR/status.sh"
        ;;
    update|up)
        bash "$CLI_DIR/update.sh"
        ;;
    doctor|doc)
        bash "$CLI_DIR/doctor.sh"
        ;;
    downloads|dl)
        shift
        bash "$CLI_DIR/downloads.sh" "$@"
        ;;
    vpn)
        bash "$CLI_DIR/vpn.sh"
        ;;
    logs|log)
        shift
        bash "$CLI_DIR/logs.sh" "$@"
        ;;
    restart)
        shift
        bash "$CLI_DIR/restart.sh" "$@"
        ;;
    stop)
        shift
        bash "$CLI_DIR/stop.sh" "$@"
        ;;
    request|req)
        shift
        bash "$CLI_DIR/request.sh" "$@"
        ;;
    health|hp)
        bash "$CLI_DIR/health.sh"
        ;;
    backup|bk)
        shift
        bash "$CLI_DIR/backup.sh" "$@"
        ;;
    start)
        shift
        bash "$CLI_DIR/start.sh" "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    "")
        # No args: interactive menu if gum available, otherwise help
        if command -v gum &>/dev/null || [ -x /usr/local/bin/gum ]; then
            show_interactive_menu
        else
            show_help
        fi
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'arr help' for usage."
        exit 1
        ;;
esac
