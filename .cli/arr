#!/usr/bin/env bash
# arr вЂ” CLI for the Arr Media Stack
# Installed by: arr setup

set -euo pipefail

# Find where the stack is installed
ARR_HOME="$(cd "$(dirname "$(readlink -f "$0")")/.." 2>/dev/null && pwd)" 2>/dev/null || true

# If installed to /usr/local/bin, ARR_HOME is stored in a marker file
if [ -z "$ARR_HOME" ] || [ ! -f "$ARR_HOME/.cli/branding.sh" ]; then
    if [ -f "$HOME/.arr-home" ]; then
        ARR_HOME="$(cat "$HOME/.arr-home")"
    elif [ -f "$PWD/.cli/branding.sh" ]; then
        ARR_HOME="$PWD"
    else
        echo "Error: Cannot find arr stack installation."
        echo "Run 'arr setup' from inside the arr-barr directory."
        exit 1
    fi
fi

CLI_DIR="$ARR_HOME/.cli"

# в”Ђв”Ђ Interactive menu (no args + gum available) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

show_interactive_menu() {
    source "$CLI_DIR/branding.sh"
    export_gum_theme
    show_logo

    local choice
    choice=$(gum choose --header "  What would you like to do?" \
        "status     вЂ” Is everything running?" \
        "start      вЂ” Boot up the stack" \
        "stop       вЂ” Shut it all down" \
        "restart    вЂ” Restart containers" \
        "update     вЂ” Pull latest updates" \
        "request    вЂ” Search & add content" \
        "health     вЂ” Quick API health check" \
        "downloads  вЂ” Live download dashboard" \
        "vpn        вЂ” Check VPN tunnel" \
        "logs       вЂ” View service logs" \
        "backup     вЂ” Manage backups" \
        "doctor     вЂ” Diagnose & auto-fix" \
        "setup      вЂ” First-time setup" \
        "help       вЂ” Show all commands")

    # Extract the command name (everything before the first space)
    local cmd="${choice%%  *}"
    cmd="${cmd// /}"  # trim any remaining spaces

    if [ -n "$cmd" ]; then
        exec "$0" "$cmd"
    fi
}

# в”Ђв”Ђ Static help tree в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

